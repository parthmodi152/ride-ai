# Model config — use any Mastra-supported provider/model string
# Examples: anthropic/claude-sonnet-4-5, openai/gpt-5.4, google/gemini-2.5-pro
MODEL_PROVIDER=anthropic/claude-sonnet-4-5

# API key for your chosen provider
ANTHROPIC_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
# GOOGLE_GENERATIVE_AI_API_KEY=your-key-here

# Optional: enables real geocoding
# GOOGLE_PLACES_API_KEY=your-key-here
