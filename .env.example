# Required — OpenAI API key for the agent (GPT-4o-mini)
OPENAI_API_KEY=sk-...

# Optional — Google Places API key for real geocoding (falls back to hardcoded NYC landmarks)
GOOGLE_PLACES_API_KEY=

# Optional — Upstash Redis for persistent action log & telemetry (falls back to in-memory)
# KV_REST_API_URL=https://your-instance.upstash.io
# KV_REST_API_TOKEN=
# REDIS_URL=rediss://default:...@your-instance.upstash.io:6379
